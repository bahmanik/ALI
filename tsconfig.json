{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "module": "ES2022",
    "target": "ES2020",
    "lib": ["ES2023"],
    "moduleResolution": "Bundler",
    "experimentalDecorators": false, //important for gnim getter and setters
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    //path alias
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },
  }
}
